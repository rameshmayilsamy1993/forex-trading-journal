# MongoDB Atlas Connection String
# Get this from your MongoDB Atlas dashboard (Network Access > Connect > Connect your application)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/fx-journal

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Session signing secret
SESSION_SECRET=

# Optional admin seed user
# Set both values to create an admin user on startup when one does not exist.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
